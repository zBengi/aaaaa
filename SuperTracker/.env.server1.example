# ─────────────────────────────────────────────────────────
# Variables de entorno – SERVIDOR 1 (Scrapers + RabbitMQ)
# Copiar como ".env.server1" y completar con valores reales.
# NUNCA commitear el archivo ".env.server1" real.
# ─────────────────────────────────────────────────────────

# Usuario/clave de administración de RabbitMQ (NO usar "guest")
RABBITMQ_DEFAULT_USER=cambiar_usuario_admin
RABBITMQ_DEFAULT_PASS=cambiar_password_admin_fuerte

# Usuario dedicado para los scrapers (solo permiso "write" sobre precios_queue)
RABBITMQ_PUBLISHER_USER=cambiar_usuario_scraper
RABBITMQ_PUBLISHER_PASS=cambiar_password_scraper_fuerte

# Usuario dedicado para el Agregador del Servidor 2 (solo permiso "read").
# OJO: estas mismas credenciales deben copiarse también en .env.server2,
# ya que el usuario se crea aquí (Servidor 1) pero se consume allá.
RABBITMQ_CONSUMER_USER=cambiar_usuario_agregador
RABBITMQ_CONSUMER_PASS=cambiar_password_agregador_fuerte

RABBITMQ_QUEUE=precios_queue
