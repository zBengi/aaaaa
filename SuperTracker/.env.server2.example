# ─────────────────────────────────────────────────────────
# Variables de entorno – SERVIDOR 2 (API + Agregador + DB + Traefik)
# Copiar como ".env.server2" y completar con valores reales.
# NUNCA commitear el archivo ".env.server2" real.
# ─────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=superprecios
POSTGRES_USER=cambiar_usuario_db
POSTGRES_PASSWORD=cambiar_password_db_fuerte

DATABASE_URL=postgresql://cambiar_usuario_db:cambiar_password_db_fuerte@postgres:5432/superprecios

# RabbitMQ (mismo usuario "publisher"/consumidor definido en servidor 1;
# el agregador solo necesita permiso de "read" sobre precios_queue)
RABBITMQ_HOST=IP_PRIVADA_O_VPN_DEL_SERVIDOR_1
RABBITMQ_PORT=5672
RABBITMQ_QUEUE=precios_queue
RABBITMQ_CONSUMER_USER=cambiar_usuario_agregador
RABBITMQ_CONSUMER_PASS=cambiar_password_agregador_fuerte

# CORS – dominio(s) real(es) del frontend, separados por coma
CORS_ALLOWED_ORIGINS=https://superprecios.cl

# Traefik / Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@superprecios.cl
TRAEFIK_DOMAIN=superprecios.cl
TRAEFIK_DASHBOARD_USER=admin
# Generar con: htpasswd -nB admin   (o "openssl passwd -apr1")
TRAEFIK_DASHBOARD_HASH=$$apr1$$cambiar$$estehashconhtpasswd
